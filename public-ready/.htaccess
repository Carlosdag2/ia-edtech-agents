<IfModule mod_rewrite.c>
RewriteEngine On

# Subdirectory base on Dinahosting
RewriteBase /oficina-agentica-edtech/

RewriteRule ^api/ - [L]
RewriteRule ^index\.html$ - [L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.html [L]
</IfModule>
